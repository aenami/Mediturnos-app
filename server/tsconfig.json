{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          /* Cambio clave */
    "moduleResolution": "NodeNext", /* Cambio clave */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}